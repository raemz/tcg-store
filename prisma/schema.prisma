// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
enum MtgColor {
    W // White
    U // Blue
    B // Black
    R // Red
    G // Green
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts for Migrate.
}

// MTG? POKEMON? YUGIOH? 
model Game {
  id         Int    @id @default(autoincrement())
  name       String
  identifier String @unique

  // many cardsets
  sets CardSet[]
}

// Bloomburrow? Duskmourne? Mega Evolution? [kapag nag add for pokemon may mga series pa and sa series nandon yung mga sets nila dagdag problema pa] 
model CardSet {
  id          Int      @id @default(autoincrement())
  gameId      Int // FK
  name        String
  code        String @unique
  releaseDate DateTime

  // one game
  game Game @relation(fields: [gameId], references: [id])

  // many printings
  printings CardPrinting[]
}

// The actual cards
model CardPrinting {
  id        Int @id @default(autoincrement())
  cardSetId Int // FK

  // stats
  name            String
  collectorNumber String
  rarity          String
  imageUrl        String
  oracleText      String?
  manaCost        String?
  colors          MtgColor[]

  cardSet CardSet @relation(fields: [cardSetId], references: [id])

  // many variants
  variants CardVariant[]

  @@unique([cardSetId, collectorNumber])
}

// parang mga PSA but for MTG
model CardVariant {
  id         Int     @id @default(autoincrement())
  printingId Int // FK
  condition  String
  language   String
  foil       Boolean

  // one printing
  printing CardPrinting @relation(fields: [printingId], references: [id])

  inventory Inventory?

  @@unique([printingId, condition, language, foil])
  saleItems SaleItem[]
}

// stock
model Inventory {
  id        Int     @id @default(autoincrement())
  variantId Int     @unique // FK
  quantity  Int

  costPrice     Decimal @db.Decimal(10, 2) // max 99999999.99
  sellPrice      Decimal @db.Decimal(10, 2) // max 99999999.99

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // if ever damaged or something, add notes here
  notes String?

  variant CardVariant @relation(fields: [variantId], references: [id])
}

// receipts
model Sale {
  id Int @id @default(autoincrement())
  soldAt DateTime @default(now())
  total Decimal @db.Decimal(10, 2) // max 99999999.99

  items SaleItem[]
}

// items in a receipt
model SaleItem {
  id Int @id @default(autoincrement())
  saleId Int // FK
  variantId Int // FK
  quantity Int

  costPrice Decimal @db.Decimal(10, 2) // max 99999999.99
  sellPrice Decimal @db.Decimal(10, 2) // max 99999999

  sale Sale @relation(fields: [saleId], references: [id])

  variant CardVariant @relation(fields: [variantId], references: [id])
}
